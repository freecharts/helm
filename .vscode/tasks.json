{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run template postgres",
            "type": "shell",
            "command": "microk8s",
            "args": [
                "helm",
                "template",
                "dbtest",
                "./postgres",
                "--namespace",
                "test",
                "--values",
                "../helm_debug/postgres-values.yaml",
                "--dry-run",
                ">",
                "../helm_debug/db.yaml"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }

        }
    ]
}